    <nodes>
      <node id="中国" label="中国">
        <attvalues>
          <attvalue for="0" value="地点" />
          <attvalue for="1" value="中国是近现代史的主体，经历了从1840年鸦片战争到1949年中华人民共和国成立的近代史，以及之后的现代史。中国人民在此期间为救亡图存和实现中华民族伟大复兴进行了英勇奋斗和艰辛探索&gt;" />
          <attvalue for="2" value="0" />
        </attvalues>
      </node>
      <node id="中华人民共和国" label="中华人民共和国">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="中华人民共和国是在1949年成立的国家，标志着中国现代史的开始，是由中国共产党领导下的全国各族人民经过斗争赢得的民族独立和人民解放的成果&gt;" />
          <attvalue for="2" value="0" />
        </attvalues>
      </node>
      <node id="中国共产党" label="中国共产党">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="中国共产党是领导全国各族人民进行斗争，赢得民族独立、人民解放，建立中华人民共和国的政党&gt;" />
          <attvalue for="2" value="0" />
        </attvalues>
      </node>
      <node id="中国近代史" label="中国近代史">
        <attvalues>
          <attvalue for="0" value="时期" />
          <attvalue for="1" value="中国近代史是指从1840年鸦片战争爆发到1949年中华人民共和国成立前夕的历史&gt;" />
          <attvalue for="2" value="0" />
        </attvalues>
      </node>
      <node id="中国现代史" label="中国现代史">
        <attvalues>
          <attvalue for="0" value="时期" />
          <attvalue for="1" value="中国现代史是指1949年中华人民共和国成立以来的历史&gt;" />
          <attvalue for="2" value="0" />
