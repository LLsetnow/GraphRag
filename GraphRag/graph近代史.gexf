      <node id="中国封建社会" label="中国封建社会">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="中国封建社会是以个体家庭为单位并与家庭手工业牢固结合的小农经济为基本生产结构的社会，自给自足的自然经济占主要地位。政治的基本特征是实行高度中央集权的封建君主专制制度。经济、政治、文化、社会结构一方面巩固和维系了封建社会的稳定和延续，另一方面也使其前进缓慢甚至迟滞，并造成不可克服的周期性的政治经济危机。&gt;" />
          <attvalue for="2" value="9" />
        </attvalues>
      </node>
      <node id="农民" label="农民">
        <attvalues>
          <attvalue for="0" value="人名" />
