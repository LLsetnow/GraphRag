      <node id="资本－帝国主义" label="资本－帝国主义">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="资本－帝国主义是文中提到的外国侵略势力，逐步操纵了中国的财政和经济命脉，并控制了中国的政治&gt;&#10;资本－帝国主义是指向中国发动侵略战争的外国势力，与中国存在主要的矛盾&gt;" />
          <attvalue for="2" value="16,14" />
          <attvalue for="3" value="组织" />
        </attvalues>
      </node>
      <node id="封建势力" label="封建势力">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="封建势力是中国的内部势力，与外国侵略势力勾结，成为压迫中国人民的社会基础和统治支柱&gt;" />
          <attvalue for="2" value="14" />
        </attvalues>
      </node>
      <node id="民族资本主义经济" label="民族资本主义经济">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="民族资本主义经济是中国新兴的经济形式，但在帝国主义和封建主义的压迫下发展缓慢&gt;" />
          <attvalue for="2" value="14" />
        </attvalues>
      </node>
      <node id="官僚资本" label="官僚资本">
        <attvalues>
          <attvalue for="0" value="组织" />
          <attvalue for="1" value="官僚资本是依附于外国资本的势力，在中国资本主义经济中居于主要和支配的地位&gt;" />
          <attvalue for="2" value="14" />
        </attvalues>
      </node>
      <node id="城居地主" label="城居地主">
        <attvalues>
          <attvalue for="0" value="人名" />
          <attvalue for="1" value="城居地主是从乡村迁往城市的地主，一部分将土地剥削获得的货币投资于资本主义工商业，有的转化为资本家，一些城居地主也往往兼营土地、高利贷和工商业。&gt;" />
          <attvalue for="2" value="15" />
        </attvalues>
      </node>
      <node id="中国资产阶级" label="中国资产阶级">
        <attvalues>
          <attvalue for="0" value="人名" />
          <attvalue for="1" value="中国资产阶级是近代中国新产生的阶级，主要由一些买办、商人、地主、官僚投资新式企业转化而成，来源不同，构成比较复杂。&gt;" />
          <attvalue for="2" value="15" />
        </attvalues>
      </node>
      <node id="官僚买办资本家" label="官僚买办资本家">
        <attvalues>
          <attvalue for="0" value="人名" />
          <attvalue for="1" value="官僚买办资本家是利用政治特权和与外国资本的紧密联系，在剥削劳动人民和挤压民族资本的过程中，逐渐形成和发展起来的中国资产阶级的一部分。&gt;" />
          <attvalue for="2" value="15" />
        </attvalues>
      </node>
      <node id="民族资本家" label="民族资本家">
        <attvalues>
          <attvalue for="0" value="人名" />
          <attvalue for="1" value="民族资本家是中国资产阶级的一部分，他们经营的企业大多数规模小、设备落后，发展缓慢，始终未能在中国社会经济中占主要地位，在政治上表现出两面性。&gt;" />
          <attvalue for="2" value="15" />
        </attvalues>
      </node>
